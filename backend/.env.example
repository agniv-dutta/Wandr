# ============================================================
# Travel Planning Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Groq API key — get yours free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ExchangeRate-API key — free tier at https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# Travelpayouts (free tier) API token — https://support.travelpayouts.com/hc/en-us/articles/203956163-API
TRAVELPAYOUTS_API_TOKEN=your_travelpayouts_api_token_here
